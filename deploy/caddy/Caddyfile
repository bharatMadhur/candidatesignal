{$APEX_DOMAIN}, {$WWW_DOMAIN} {
	redir https://{$APP_DOMAIN}{uri} permanent
}

{$APP_DOMAIN} {
	encode zstd gzip

	handle /api/auth/me {
		uri strip_prefix /api
		reverse_proxy api:8010
	}

	handle /api/auth/logout {
		uri strip_prefix /api
		reverse_proxy api:8010
	}

	handle /api/auth/bootstrap {
		uri strip_prefix /api
		reverse_proxy api:8010
	}

	handle /api/auth/company-signup {
		uri strip_prefix /api
		reverse_proxy api:8010
	}

	handle /api/auth/platform/* {
		uri strip_prefix /api
		reverse_proxy api:8010
	}

	handle /api/auth/* {
		reverse_proxy ui:3001
	}

	handle /api/backend/* {
		reverse_proxy ui:3001
	}

	handle_path /api/* {
		reverse_proxy api:8010
	}

	handle /healthz* {
		reverse_proxy api:8010
	}

	reverse_proxy ui:3001
}

{$STAGING_DOMAIN:staging-disabled.invalid} {
	encode zstd gzip

	header {
		X-Robots-Tag "noindex, nofollow, noarchive"
	}

	handle /robots.txt {
		respond "User-agent: *\nDisallow: /\n" 200
	}

	handle /api/* {
		reverse_proxy ui-staging:3001
	}

	handle /healthz* {
		reverse_proxy api-staging:8010
	}

	reverse_proxy ui-staging:3001
}
