	handle /api/auth/* {
		reverse_proxy ui:3001
	}

	handle /api/backend/* {
		reverse_proxy ui:3001
	}

	handle_path /api/* {
		reverse_proxy api:8010
	}

	handle /healthz* {
		reverse_proxy api:8010
	}

	reverse_proxy ui:3001
}
