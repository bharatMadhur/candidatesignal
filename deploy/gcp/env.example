PROJECT_ID=candidatesignal
REGION=us-central1
ZONE=us-central1-a
APEX_DOMAIN=candidatesignal.ai
WWW_DOMAIN=www.candidatesignal.ai
APP_DOMAIN=app.candidatesignal.ai

ARTIFACT_REPOSITORY=candidatesignal
DOCUMENT_BUCKET=candidatesignal-prod-documents

SQL_INSTANCE=candidatesignal-postgres
SQL_EDITION=enterprise
SQL_DATABASE=resume_intel
SQL_USER=resume_intel
SQL_TIER=db-f1-micro
SQL_STORAGE_GB=20
SQL_BACKUP_START_TIME=09:00
SQL_BACKUP_RETENTION_COUNT=8
SQL_PITR_RETENTION_DAYS=3

OCR_SERVICE=candidatesignal-ocr
OCR_CPU=4
OCR_MEMORY=16Gi
OCR_TIMEOUT=3600
OCR_MAX_INSTANCES=1
OCR_MIN_INSTANCES=0

VM_NAME=candidatesignal-app-1
VM_MACHINE_TYPE=e2-medium
VM_BOOT_DISK_SIZE=30GB

VM_SERVICE_ACCOUNT=cs-vm-sa
OCR_SERVICE_ACCOUNT=cs-ocr-sa
BUILD_SERVICE_ACCOUNT=cs-build-sa

# Optional. If set, operational alerts are delivered externally through this
# webhook in addition to the in-app Operations view. Keep this in env.local or
# Secret Manager, never committed with a real tokenized URL.
RESUME_INTEL_ALERT_WEBHOOK_URL=

# Optional. Enables manual LinkedIn verification through Apify/HarvestAPI.
# Keep the real token in env.local or Secret Manager, not in git.
APIFY_API_TOKEN=
LINKEDIN_APIFY_ACTOR_ID=LpVuK3Zozwuipa5bp
LINKEDIN_APIFY_SCRAPER_MODE=Profile details no email ($4 per 1k)
